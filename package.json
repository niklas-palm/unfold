{
  "name": "unfold-ai",
  "version": "0.1.7",
  "description": "The presentation framework for AI agents — animated diagram-based technical presentations from TypeScript data files",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "examples/dns",
    "examples/k8s",
    "examples/transformer-architecture",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "examples": "vite --open /examples.html",
    "build": "vite build",
    "build:lib": "tsup",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "framer-motion": ">=10.0.0",
    "prism-react-renderer": ">=2.0.0"
  },
  "devDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "framer-motion": "^12.35.2",
    "prism-react-renderer": "^2.4.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vite": "^7.3.1"
  },
  "keywords": [
    "presentation",
    "slides",
    "diagram",
    "architecture",
    "ai",
    "agent",
    "react",
    "typescript",
    "animation",
    "technical"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niklas-palm/unfold.git"
  },
  "homepage": "https://github.com/niklas-palm/unfold#readme"
}
